# Database
DATABASE_URL="postgresql://username:password@localhost:5432/pakistan_olx_db?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production"

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# App Config
NEXT_PUBLIC_APP_NAME="Pakistan Marketplace"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_FEATURED_AD_PRICE="2000"
NEXT_PUBLIC_FEATURED_AD_DURATION="7"

# Admin Default Credentials (for seeding)
ADMIN_EMAIL="admin@marketplace.pk"
ADMIN_PASSWORD="admin123456"
ADMIN_NAME="System Admin"

# Email Configuration (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
APP_NAME="Pakistan Marketplace"

# ─── Socket.io Server ──────────────────────────────────────────────────────────
# Port the standalone Socket.io server listens on (default: 3001)
SOCKET_PORT="3001"

# Shared secret between Next.js and the socket server for the /emit endpoint
# CHANGE THIS in production to a long random string!
SOCKET_SECRET="dev-secret-change-in-prod"

# URL Next.js API routes use internally to reach the socket server
# Dev:  http://localhost:3001
# Prod: http://localhost:3001  (or internal docker network URL)
SOCKET_SERVER_URL="http://localhost:3001"

# URL the browser (client-side) uses to connect to the socket server
# Dev:  http://localhost:3001
# Prod: https://socket.yourdomain.com  (put behind nginx/Cloudflare)
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"

# CORS origins allowed by the socket server (comma-separated)
# Dev:  http://localhost:3000
# Prod: https://yourdomain.com
SOCKET_CORS_ORIGIN="http://localhost:3000"
